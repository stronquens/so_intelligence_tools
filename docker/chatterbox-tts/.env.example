CHATTERBOX_TTS_PORT=9011
CHATTERBOX_TTS_STARTUP_TIMEOUT_SECONDS=600
CHATTERBOX_TTS_DEVICE=cuda
CHATTERBOX_TTS_MODEL_DIR=/var/lib/chatterbox-tts/models
CHATTERBOX_TTS_DEFAULT_VOICE=female
CHATTERBOX_TTS_MODEL_REPO=ResembleAI/chatterbox
CHATTERBOX_TTS_ES_ES_REPO=ResembleAI/Chatterbox-Multilingual-es-es

# Voice presets accepted by POST /v1/audio/speech {"voice": "..."}.
# `male` uses the built-in Chatterbox conditioning from the shared checkpoint.
# `female` uses the user-selected Common Voice reference clone.
CHATTERBOX_TTS_FEMALE_REFERENCE=/app/voices/common_voice_female_es_ref_01_row_410.wav
CHATTERBOX_TTS_MALE_EXAGGERATION=0.5
CHATTERBOX_TTS_MALE_CFG_WEIGHT=0.5
CHATTERBOX_TTS_MALE_TEMPERATURE=0.8
CHATTERBOX_TTS_FEMALE_EXAGGERATION=0.65
CHATTERBOX_TTS_FEMALE_CFG_WEIGHT=0.35
CHATTERBOX_TTS_FEMALE_TEMPERATURE=0.75
