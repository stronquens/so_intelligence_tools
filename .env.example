# Local API
LOCAL_INFERENCE_API_HOST=127.0.0.1
LOCAL_INFERENCE_API_PORT=8010
LOCAL_INFERENCE_API_BASE_URL=http://127.0.0.1:8010

# Local inference
INFERENCE_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4-e2b-longctx:latest
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_KEEP_ALIVE=24h
OLLAMA_WARMUP_ON_STARTUP=true

# Desktop shortcuts
GNOME_SELECTED_TEXT_CORRECTION_BINDING=<Primary><Alt>c
WINDOWS_SELECTED_TEXT_CORRECTION_SHORTCUT=<ctrl>+<alt>+c
SHORTCUT_ACTION_COOLDOWN_SECONDS=2.0
GNOME_SYSTEM_AUDIO_TRANSLATION_BINDING=<Primary><Alt>y
GNOME_VOICE_TRANSLATION_BINDING=<Primary><Alt>u

# Push-to-talk dictation
PUSH_TO_TALK_DICTATION_SHORTCUT=<ctrl>+<alt>+<space>
WINDOWS_PUSH_TO_TALK_DICTATION_SHORTCUT=<ctrl>+<space>
PUSH_TO_TALK_DICTATION_RUNTIME=faster_whisper_http
PUSH_TO_TALK_DICTATION_LANGUAGE=es-ES
PUSH_TO_TALK_DICTATION_FASTER_WHISPER_BASE_URL=http://127.0.0.1:9000
PUSH_TO_TALK_DICTATION_FASTER_WHISPER_MODEL=whisper-1
PUSH_TO_TALK_DICTATION_FASTER_WHISPER_TIMEOUT_SECONDS=30
PUSH_TO_TALK_DICTATION_SAMPLE_RATE_HZ=16000
PUSH_TO_TALK_DICTATION_CHUNK_MS=560
PUSH_TO_TALK_DICTATION_POST_ROLL_SECONDS=0.35
PUSH_TO_TALK_DICTATION_INSERTION_STRATEGY=final_segments
# Optional Windows sounddevice input device index or name.
PUSH_TO_TALK_DICTATION_MICROPHONE_SOURCE=

# OpenAI direct API for realtime audio tools.
# Keep the real key only in .env, never in this example file.
OPENAI_API_KEY=

# System audio -> Spanish text translation
SYSTEM_AUDIO_TRANSLATION_MODE=translate_es_openai_realtime
SYSTEM_AUDIO_TRANSLATION_SOURCE_LANGUAGE=auto
SYSTEM_AUDIO_TRANSLATION_TARGET_LANGUAGE=es
SYSTEM_AUDIO_TRANSLATION_OPENAI_REALTIME_MODEL=gpt-realtime

# Your Spanish voice -> translated virtual microphone audio
VOICE_TRANSLATION_SOURCE_LANGUAGE=Spanish
VOICE_TRANSLATION_TARGET_LANGUAGE=English
VOICE_TRANSLATION_OPENAI_MODEL=gpt-realtime-translate
VOICE_TRANSLATION_VOICE=marin
VOICE_TRANSLATION_SAMPLE_RATE_HZ=24000
VOICE_TRANSLATION_CHUNK_MS=80
# Optional exact PulseAudio source. Useful when the laptop has more than one microphone.
# Example: VOICE_TRANSLATION_PHYSICAL_SOURCE=alsa_input.usb-046d_C922_Pro_Stream_Webcam_719B22BF-02.analog-stereo
VOICE_TRANSLATION_PHYSICAL_SOURCE=
VOICE_TRANSLATION_PASSTHROUGH_VOLUME=1.0
VOICE_TRANSLATION_DUCKED_PASSTHROUGH_VOLUME=0.03
VOICE_TRANSLATION_MAX_DUCKED_PASSTHROUGH_VOLUME=0.12
VOICE_TRANSLATION_OUTPUT_VOLUME=0.75
# Public microphone source name. The internal PulseAudio sink is derived from this value.
VOICE_TRANSLATION_VIRTUAL_SINK_NAME=so_ai_translated_mic
VOICE_TRANSLATION_DEBUG_RECORDING_ENABLED=false
VOICE_TRANSLATION_DEBUG_RECORDINGS_DIR=~/.cache/so_intelligence_tools/voice_translation_debug_audio
